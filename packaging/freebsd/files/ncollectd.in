#!/bin/sh

# PROVIDE: ncollectd
# REQUIRE: LOGIN
#
# Add the following lines to /etc/rc.conf.local or /etc/rc.conf
# to enable this service:
#
# ncollectd_enable (bool):       Set to NO by default.
#               Set it to YES to enable collectd.
# ncollectd_flags (string):      Set to "" by default.
#               Additional flags to collectd, see manual page.
#

. /etc/rc.subr

name="ncollectd"
rcvar=ncollectd_enable

command=%%PREFIX%%/sbin/${name}

load_rc_config $name

: ${ncollectd_enable="NO"}

run_rc_command "$1"
