          "mappings": [
            {
              "options": {
                "1": {
                  "color": "red",
                  "index": 0,
                  "text": "DOWN"
                },
                "2": {
                  "color": "green",
                  "index": 1,
                  "text": "UP"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "match": "null+nan",
                "result": {
