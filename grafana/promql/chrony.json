      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "nomal"
                },
                "1": {
                  "color": "purple",
                  "index": 1,
                  "text": "insert second"
                },
                "2": {
                  "color": "orange",
                  "index": 2,
                  "text": "delete second"
                },
                "3": {
                  "color": "red",
                  "index": 3,
                  "text": "not syncronized"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "match": "null+nan",
                "result": {
                  "index": 4,
                  "text": "Unknow"
                }
              },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "none"
        },
